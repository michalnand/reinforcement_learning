set   autoscale                        # scale axes automatically
unset log                              # remove any log-scaling
unset label                            # remove any previous labels
set xtic auto                         	# set xtics automatically
set ytic auto                         # set ytics automatically
set ztic auto


set grid ytics lt 0.1 lw 0.1 lc rgb "#bbbbbb"
set grid xtics lt 0.1 lw 0.1 lc rgb "#bbbbbb"

#set terminal png size 2048,1356 enhanced font "Helvetica,20"
set terminal png size 1024,768 enhanced font "Helvetica,20"

set key left top

# set style fill solid 1.0





set xlabel "iterations"
set output 'training_score_per_game_iterations.png'
plot './a/result/training_progress.log' using 1:7 title 'a'  with lines lw 3, \
     './b/result/training_progress.log' using 1:7 title 'b'  with lines lw 3, \
     './c/result/training_progress.log' using 1:7 title 'c'  with lines lw 3
